{
  "repo_owner": "yevgetman",
  "repo_name": "django-munky",
  "prod_branch": "main",
  "staging_branch": "staging",
  "backend_test_cmd": "python manage.py test api.tests --noinput",
  "frontend_test_cmd": "npm test",
  "frontend_dir": "frontend-legacy",
  "frontend_build_cmd": "npm run build",
  "migration_cmd": "python manage.py migrate",
  "backend_app_staging": "django-munky-staging",
  "backend_app_prod": "django-munky-v2",
  "frontend_project_staging": "django-munky-staging",
  "frontend_project_prod": "django-munky-prod",
  "db_service": "mysql",
  "python_version": "3.12",
  "node_version_file": "frontend-legacy/.nvmrc",
  "backend_platform": "heroku",
  "frontend_platform": "cloudflare-pages",
  "tracks": [
    {
      "name": "saas",
      "id_prefix": "I",
      "branch_prefix": "roadmap",
      "issue_label": "roadmap-saas",
      "commit_prefix": "roadmap",
      "north_star": "Self-serve SaaS product: public signup, Stripe billing, tenant provisioning, plan enforcement.",
      "cron": "0 */6 * * *"
    },
    {
      "name": "platform",
      "id_prefix": "P",
      "branch_prefix": "platform",
      "issue_label": "roadmap-platform",
      "commit_prefix": "platform",
      "north_star": "Platform improvements: refactors, ops/reliability, DX, performance, observability, UX polish.",
      "cron": "0 1/6 * * *"
    },
    {
      "name": "ai",
      "id_prefix": "A",
      "branch_prefix": "ai",
      "issue_label": "roadmap-ai",
      "commit_prefix": "ai",
      "north_star": "AI-powered features: in-app assistant, smart suggestions, analytics insights.",
      "cron": "0 3/6 * * *"
    }
  ],
  "adhoc_agent": true,
  "adhoc_cron": "0 2/6 * * *"
}
