name: Deploy - Production Frontend

# Auto-deploy the frontend to Cloudflare Pages after CI passes on
# the production branch.
#
# Required GitHub repo secrets:
#   CLOUDFLARE_API_TOKEN   — token with "Cloudflare Pages — Edit"
#   CLOUDFLARE_ACCOUNT_ID  — your Cloudflare account ID

on:
  workflow_run:
    workflows: ["Frontend Tests"]
    types: [completed]
    branches: [${__PROD_BRANCH}]

concurrency:
  group: deploy-prod-frontend
  cancel-in-progress: true

jobs:
  deploy:
    name: Build + deploy to ${__FRONTEND_PROJECT_PROD}
    if: ${{ github.event.workflow_run.conclusion == 'success' }}
    runs-on: ubuntu-latest
    timeout-minutes: 15
    defaults:
      run:
        working-directory: ${__FRONTEND_DIR}

    steps:
      - uses: actions/checkout@v4

      - name: Set up Node
        uses: actions/setup-node@v4
        with:
          node-version-file: ${__NODE_VERSION_FILE}
          cache: npm
          cache-dependency-path: ${__FRONTEND_DIR}/package-lock.json

      - name: Install npm dependencies
        run: npm ci --no-audit --no-fund

      - name: Run tests
        run: ${__FRONTEND_TEST_CMD}

      - name: Build
        run: ${__FRONTEND_BUILD_CMD}

      - name: Deploy to Cloudflare Pages (production)
        uses: cloudflare/wrangler-action@v3
        with:
          apiToken: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          accountId: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
          workingDirectory: ${__FRONTEND_DIR}
          command: pages deploy dist --project-name=${__FRONTEND_PROJECT_PROD} --branch=${__PROD_BRANCH} --commit-dirty=true
