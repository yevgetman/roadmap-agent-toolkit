name: Deploy - Production Frontend

# Auto-deploy the frontend to Vercel after CI passes on the
# production branch.
#
# Required GitHub repo secrets:
#   VERCEL_TOKEN      — Vercel personal access token
#   VERCEL_ORG_ID     — your Vercel org/team ID
#   VERCEL_PROJECT_ID — your Vercel project ID

on:
  workflow_run:
    workflows: ["Frontend Tests"]
    types: [completed]
    branches: [${__PROD_BRANCH}]

concurrency:
  group: deploy-prod-frontend
  cancel-in-progress: true

jobs:
  deploy:
    name: Build + deploy to Vercel (production)
    if: ${{ github.event.workflow_run.conclusion == 'success' }}
    runs-on: ubuntu-latest
    timeout-minutes: 15

    steps:
      - uses: actions/checkout@v4

      - name: Set up Node
        uses: actions/setup-node@v4
        with:
          node-version-file: ${__NODE_VERSION_FILE}
          cache: npm
          cache-dependency-path: ${__FRONTEND_DIR}/package-lock.json

      - name: Install npm dependencies
        working-directory: ${__FRONTEND_DIR}
        run: npm ci --no-audit --no-fund

      - name: Run tests
        working-directory: ${__FRONTEND_DIR}
        run: ${__FRONTEND_TEST_CMD}

      - name: Install Vercel CLI
        run: npm install --global vercel@latest

      - name: Pull Vercel environment info
        run: vercel pull --yes --environment=production --token=${{ secrets.VERCEL_TOKEN }}
        env:
          VERCEL_ORG_ID: ${{ secrets.VERCEL_ORG_ID }}
          VERCEL_PROJECT_ID: ${{ secrets.VERCEL_PROJECT_ID }}

      - name: Build
        run: vercel build --prod --token=${{ secrets.VERCEL_TOKEN }}
        env:
          VERCEL_ORG_ID: ${{ secrets.VERCEL_ORG_ID }}
          VERCEL_PROJECT_ID: ${{ secrets.VERCEL_PROJECT_ID }}

      - name: Deploy to Vercel (production)
        run: vercel deploy --prebuilt --prod --token=${{ secrets.VERCEL_TOKEN }}
        env:
          VERCEL_ORG_ID: ${{ secrets.VERCEL_ORG_ID }}
          VERCEL_PROJECT_ID: ${{ secrets.VERCEL_PROJECT_ID }}
