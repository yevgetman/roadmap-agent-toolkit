name: Deploy — Production Frontend

# Auto-deploy frontend to Netlify after CI passes on production.
#
# Required GitHub repo secrets:
#   NETLIFY_AUTH_TOKEN  — Netlify personal access token

on:
  workflow_run:
    workflows: ["Frontend Tests"]
    types: [completed]
    branches: [${__PROD_BRANCH}]

concurrency:
  group: deploy-prod-frontend
  cancel-in-progress: true

jobs:
  deploy:
    name: Build + deploy to Netlify (production)
    if: ${{ github.event.workflow_run.conclusion == 'success' }}
    runs-on: ubuntu-latest
    timeout-minutes: 15
    defaults:
      run:
        working-directory: ${__FRONTEND_DIR}

    steps:
      - uses: actions/checkout@v4

      - name: Set up Node
        uses: actions/setup-node@v4
        with:
          node-version-file: ${__NODE_VERSION_FILE}
          cache: npm
          cache-dependency-path: ${__FRONTEND_DIR}/package-lock.json

      - name: Install dependencies
        run: npm ci --no-audit --no-fund

      - name: Run tests
        run: ${__FRONTEND_TEST_CMD}

      - name: Build
        run: ${__FRONTEND_BUILD_CMD}

      - name: Install Netlify CLI
        run: npm install -g netlify-cli

      - name: Deploy to Netlify (production)
        run: |
          netlify deploy --prod \
            --dir=dist \
            --site=${__NETLIFY_SITE_ID_PROD} \
            --auth=${{ secrets.NETLIFY_AUTH_TOKEN }}
