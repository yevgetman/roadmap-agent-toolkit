name: Staging Migrate

on:
  workflow_dispatch:
    inputs:
      reason:
        description: 'Why this migration run is needed'
        required: false
        default: 'ad-hoc staging migration'

  workflow_run:
    workflows: ["Tests"]
    types: [completed]
    branches: [${__STAGING_BRANCH}]

concurrency:
  group: staging-migrate
  cancel-in-progress: false

jobs:
  migrate:
    name: fly ssh migrate (${__BACKEND_APP_STAGING})
    if: ${{ github.event_name == 'workflow_dispatch' || github.event.workflow_run.conclusion == 'success' }}
    runs-on: ubuntu-latest
    timeout-minutes: 15
    env:
      FLY_API_TOKEN: ${{ secrets.FLY_API_TOKEN }}

    steps:
      - name: Install Fly CLI
        run: curl -L https://fly.io/install.sh | sh

      - name: Apply migrations
        run: |
          flyctl ssh console -a ${__BACKEND_APP_STAGING} -C '${__MIGRATION_CMD}'
