name: Frontend Deploy - Staging

# Auto-deploy the frontend to Cloudflare Pages (staging project)
# on every push to the staging branch that touches frontend files.
#
# Required GitHub repo secrets:
#   CLOUDFLARE_API_TOKEN   — token with "Cloudflare Pages — Edit"
#   CLOUDFLARE_ACCOUNT_ID  — your Cloudflare account ID

on:
  push:
    branches: [${__STAGING_BRANCH}]
    paths:
      - '${__FRONTEND_DIR}/**'
      - '.github/workflows/deploy-staging-frontend.yml'

concurrency:
  group: frontend-deploy-staging
  cancel-in-progress: true

jobs:
  deploy:
    name: Test + build + deploy to ${__FRONTEND_PROJECT_STAGING}
    runs-on: ubuntu-latest
    timeout-minutes: 15
    defaults:
      run:
        working-directory: ${__FRONTEND_DIR}

    steps:
      - uses: actions/checkout@v4

      - name: Set up Node
        uses: actions/setup-node@v4
        with:
          node-version-file: ${__NODE_VERSION_FILE}
          cache: npm
          cache-dependency-path: ${__FRONTEND_DIR}/package-lock.json

      - name: Install npm dependencies
        run: npm ci --no-audit --no-fund

      - name: Run tests
        run: ${__FRONTEND_TEST_CMD}

      - name: Build
        run: ${__FRONTEND_BUILD_CMD}

      - name: Deploy to Cloudflare Pages (staging)
        uses: cloudflare/wrangler-action@v3
        with:
          apiToken: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          accountId: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
          workingDirectory: ${__FRONTEND_DIR}
          command: pages deploy dist --project-name=${__FRONTEND_PROJECT_STAGING} --branch=${__STAGING_BRANCH} --commit-dirty=true
