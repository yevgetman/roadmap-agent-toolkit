#!/usr/bin/env bash
# roadmap-agent tick script for track: ${__TRACK_NAME}
#
# Generated by roadmap-agent-toolkit. This script runs one agent
# tick — it picks up the next item, implements it, merges to
# staging, waits for CI, and reconciles. Then exits.
#
# Invoke manually:   .roadmap/agents/tick-${__TRACK_NAME}.sh
# Scheduled via:     launchd / crontab / GH Actions / custom
#
# The script cd's to the repo root, pulls latest, and invokes
# the configured agent CLI with the AGENT_PROMPT.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
TRACK="${__TRACK_NAME}"
PROMPT_FILE="$REPO_ROOT/docs/roadmap/AGENT_PROMPT.md"
LOG_DIR="$REPO_ROOT/.roadmap/logs"

mkdir -p "$LOG_DIR"

cd "$REPO_ROOT"

# Pull latest BACKLOG + prompt from production branch
git fetch origin ${__PROD_BRANCH} --quiet
git checkout ${__PROD_BRANCH} --quiet
git pull --ff-only origin ${__PROD_BRANCH} --quiet

# Extract the prompt (between BEGIN PROMPT and END PROMPT)
PROMPT=$(sed -n '/^## BEGIN PROMPT$/,/^## END PROMPT$/p' "$PROMPT_FILE")

# Prepend the track assignment
FULL_PROMPT="Run with TRACK: $TRACK

$PROMPT"

echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] tick start: track=$TRACK"

# ── Invoke the agent CLI ──────────────────────────────────────
${__AGENT_INVOKE_COMMAND}

EXIT_CODE=$?
echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] tick end: track=$TRACK exit=$EXIT_CODE"
exit $EXIT_CODE
