#!/usr/bin/env bash
# setup-agents.sh — install or update agent scheduling
#
# Generated by roadmap-agent-toolkit. Run this after initial install
# or when tracks/scheduling config changes.
#
# Usage:
#   .roadmap/setup-agents.sh install    # install scheduler entries
#   .roadmap/setup-agents.sh uninstall  # remove scheduler entries
#   .roadmap/setup-agents.sh status     # show scheduler status
#
# Scheduler: ${__SCHEDULER}
# Runtime:   ${__AGENT_RUNTIME}

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
ACTION="${1:-status}"
SCHEDULER="${__SCHEDULER}"

# Track definitions (generated by installer)
${__TRACKS_ARRAY}

case "$SCHEDULER" in
  launchd)
    PLIST_DIR="$HOME/Library/LaunchAgents"
    mkdir -p "$PLIST_DIR"

    case "$ACTION" in
      install)
        for i in "${!TRACK_NAMES[@]}"; do
          TRACK="${TRACK_NAMES[$i]}"
          CRON="${TRACK_CRONS[$i]}"
          LABEL="com.roadmap-agent.${__REPO_NAME}.$TRACK"
          PLIST="$PLIST_DIR/$LABEL.plist"

          # Unload if already loaded
          launchctl list | grep -q "$LABEL" && launchctl unload "$PLIST" 2>/dev/null || true

          # Generate plist from template
          CADENCE_SECONDS=${__CADENCE_SECONDS}
          sed -e "s|\${__TRACK_NAME}|$TRACK|g" \
              -e "s|\${__REPO_NAME}|${__REPO_NAME}|g" \
              -e "s|\${__REPO_ROOT}|$REPO_ROOT|g" \
              -e "s|\${__CADENCE_SECONDS}|$CADENCE_SECONDS|g" \
              -e "s|\${__HOME}|$HOME|g" \
              "$REPO_ROOT/.roadmap/schedulers/launchd.plist.tmpl" > "$PLIST"

          launchctl load "$PLIST"
          echo "  Loaded: $LABEL (every ${__CADENCE_HOURS}h)"
        done
        echo "Agents installed. Check: launchctl list | grep roadmap-agent"
        ;;

      uninstall)
        for i in "${!TRACK_NAMES[@]}"; do
          TRACK="${TRACK_NAMES[$i]}"
          LABEL="com.roadmap-agent.${__REPO_NAME}.$TRACK"
          PLIST="$PLIST_DIR/$LABEL.plist"
          launchctl unload "$PLIST" 2>/dev/null && echo "  Unloaded: $LABEL" || echo "  Not loaded: $LABEL"
          rm -f "$PLIST"
        done
        ;;

      status)
        launchctl list | grep "roadmap-agent" || echo "No roadmap agents loaded"
        ;;
    esac
    ;;

  crontab)
    case "$ACTION" in
      install)
        # Remove any existing roadmap-agent entries, then add new ones
        EXISTING=$(crontab -l 2>/dev/null | grep -v "roadmap-agent" || true)
        NEW_ENTRIES=""
        for i in "${!TRACK_NAMES[@]}"; do
          TRACK="${TRACK_NAMES[$i]}"
          CRON="${TRACK_CRONS[$i]}"
          NEW_ENTRIES="$NEW_ENTRIES
$CRON cd $REPO_ROOT && .roadmap/agents/tick-$TRACK.sh >> .roadmap/logs/$TRACK.log 2>&1  # roadmap-agent:$TRACK"
        done
        echo "$EXISTING$NEW_ENTRIES" | crontab -
        echo "Agents installed. Check: crontab -l | grep roadmap-agent"
        ;;

      uninstall)
        crontab -l 2>/dev/null | grep -v "roadmap-agent" | crontab -
        echo "Roadmap agent crontab entries removed"
        ;;

      status)
        crontab -l 2>/dev/null | grep "roadmap-agent" || echo "No roadmap agents in crontab"
        ;;
    esac
    ;;

  github-actions)
    case "$ACTION" in
      install)
        echo "GitHub Actions agent workflows are in .github/workflows/agent-*.yml"
        echo "They run on the cron schedule defined in each file."
        echo "No local installation needed — push the workflow files to enable."
        ;;

      uninstall)
        echo "Delete .github/workflows/agent-*.yml and push to disable."
        ;;

      status)
        for i in "${!TRACK_NAMES[@]}"; do
          TRACK="${TRACK_NAMES[$i]}"
          echo "  agent-$TRACK.yml: ${TRACK_CRONS[$i]}"
        done
        echo "Check runs: gh run list --workflow agent-<track>.yml --limit 5"
        ;;
    esac
    ;;

  claude-code-routines)
    case "$ACTION" in
      install)
        echo "Claude Code routines are managed inside Claude Code."
        echo ""
        echo "For each track, run /schedule create in a Claude Code session:"
        for i in "${!TRACK_NAMES[@]}"; do
          TRACK="${TRACK_NAMES[$i]}"
          CRON="${TRACK_CRONS[$i]}"
          echo ""
          echo "  Track: $TRACK"
          echo "  Cron:  $CRON"
          echo "  Model: ${__AGENT_MODEL}"
          echo "  Prompt: contents of docs/roadmap/AGENT_PROMPT.md"
          echo "          (BEGIN PROMPT to END PROMPT) with TRACK: $TRACK"
        done
        echo ""
        echo "Record each routine ID in BACKLOG.yml under"
        echo "tracks.<name>.meta.scheduled_agent_routine_id"
        echo ""
        echo "Manage at: https://claude.ai/code/routines"
        ;;

      uninstall)
        echo "Delete routines at: https://claude.ai/code/routines"
        ;;

      status)
        echo "Check routine status at: https://claude.ai/code/routines"
        ;;
    esac
    ;;

  *)
    echo "Scheduler: custom"
    echo "Tick scripts are at .roadmap/agents/tick-<track>.sh"
    echo "Schedule them with your preferred mechanism."
    for i in "${!TRACK_NAMES[@]}"; do
      TRACK="${TRACK_NAMES[$i]}"
      CRON="${TRACK_CRONS[$i]}"
      echo "  $TRACK: $CRON → .roadmap/agents/tick-$TRACK.sh"
    done
    ;;
esac
